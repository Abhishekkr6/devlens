{
    "name": "DevLens-vscode",
    "displayName": "DevLens",
    "description": "Real-time engineering insights for your GitHub repositories",
    "version": "0.1.0",
    "publisher": "DevLens",
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "github",
        "pull request",
        "code review",
        "engineering metrics",
        "team collaboration"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "DevLens",
                    "title": "DevLens",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "DevLens": [
                {
                    "type": "webview",
                    "id": "DevLens.sidebar",
                    "name": "Repository Insights"
                }
            ]
        },
        "commands": [
            {
                "command": "DevLens.login",
                "title": "DevLens: Login with GitHub"
            },
            {
                "command": "DevLens.logout",
                "title": "DevLens: Logout"
            },
            {
                "command": "DevLens.refresh",
                "title": "DevLens: Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "DevLens.openDashboard",
                "title": "DevLens: Open Dashboard"
            }
        ],
        "configuration": {
            "title": "DevLens",
            "properties": {
                "DevLens.apiUrl": {
                    "type": "string",
                    "default": "https://DevLens-production.up.railway.app",
                    "description": "DevLens API base URL"
                },
                "DevLens.dashboardUrl": {
                    "type": "string",
                    "default": "https://DevLens18.vercel.app",
                    "description": "DevLens dashboard URL"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "lint": "eslint src --ext ts",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "@vscode/vsce": "^2.22.0",
        "eslint": "^8.0.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "canvas": "^3.2.1"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Abhishekkr6/DevLens"
    },
    "license": "MIT"
}